# Application
APP_NAME="Event Planner API"
APP_VERSION="0.1.0"
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://event_planner:event_planner@localhost:5432/event_planner

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Uploads
UPLOAD_DIR=uploads/contracts

# SMTP (Notifications)
SMTP_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@eventplanner.local
SMTP_USE_TLS=true

# Frontend URL (billing redirects)
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
